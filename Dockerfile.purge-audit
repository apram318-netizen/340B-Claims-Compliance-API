# syntax=docker/dockerfile:1

FROM golang:1.23-alpine AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -trimpath -ldflags="-s -w" -o /out/purge-audit ./cmd/purge-audit

FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /out/purge-audit /purge-audit

ENTRYPOINT ["/purge-audit"]
