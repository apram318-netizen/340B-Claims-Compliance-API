# Copy this to .env and fill in values. Never commit .env to version control.

# API server
PORT=8080

# PostgreSQL connection string
DATABASE_URL=postgres://claims:claims@localhost:5432/claims_dev

# RabbitMQ connection string
AMQP_URL=amqp://guest:guest@localhost:5672/

# Redis (used for production rate limiting, session caching)
REDIS_URL=redis://localhost:6379/0

# JWT secret — must be at least 32 random characters in production
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars

# CORS — set to your exact frontend origin in production (example: https://app.example.com)
# If unset, cross-origin browser requests are blocked by default.
ALLOWED_ORIGIN=

# Worker metrics/probes bind port
WORKER_METRICS_PORT=9091
